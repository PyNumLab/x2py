def zero_vector() -> Float64[0]: ...

def zero_alloc_vector() -> Allocatable[Float64[:]]: ...

@native_call([Addr(Arg(0))])
def maybe_alloc_vector(
    n: Int32
) -> Allocatable[Float64[:]]: ...
