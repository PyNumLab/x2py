  "source": "subroutine daxpy_like(n, alpha, x, y)\n  integer, intent(in) :: n\n  real(kind=8), intent(in) :: alpha\n  real(kind=8), intent(in), dimension(n) :: x\n  real(kind=8), intent(inout), dimension(n) :: y\n  y = y + alpha * x\nend subroutine daxpy_like\n",
