  "source": "subroutine row_sums_c(n, values, result)\n  integer, intent(in) :: n\n  double precision, intent(in) :: values(*)\n  double precision, intent(out) :: result(*)\n  integer :: i\n\n  do i = 1, n\n    result(i) = values((i - 1) * 3 + 1) + values((i - 1) * 3 + 2) + values((i - 1) * 3 + 3)\n  end do\nend subroutine row_sums_c\n",
