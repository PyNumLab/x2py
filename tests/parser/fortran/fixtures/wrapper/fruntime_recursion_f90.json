  "filename": "wrapper/fruntime_recursion_f90.f90",
  "source": "module fruntime_recursion_f90\ncontains\n  recursive integer function factorial(n) result(output)\n    integer, intent(in) :: n\n    if (n <= 1) then\n      output = 1\n    else\n      output = n * factorial(n - 1)\n    end if\n  end function factorial\n\n  integer function add_one(n) result(output)\n    integer, intent(in) :: n\n    output = n + 1\n  end function add_one\nend module fruntime_recursion_f90\n",
