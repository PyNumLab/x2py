{
  "filename": "SciFortran/01_test_sf_timer.f90",
  "source": "program test_SF_TIMER\n  USE SF_CONSTANTS\n  USE SF_TIMER\n  USE ASSERTING\n  USE SF_MPI\n  implicit none\n\n  integer :: i\n  integer :: rank,size\n  \n  call init_MPI()\n  rank = get_rank_MPI()\n  size = get_size_MPI()\n  \n  call start_timer()\n\n  call start_timer(\"Loop 100x30ms = 3s\",unit=6+2*rank)\n  do i=1+rank,100,size\n     call wait(30)\n     call eta(i,100)\n  enddo\n  call stop_timer(\"timer + ETA example\")\n\n  \n  call start_progress(\"Loop 100x25ms\")\n  do i=1,100\n     call wait(25)\n     call progress(i,100)\n  enddo\n  call stop_progress(\"progress + ETA example\")\n\n\n  call stop_timer(\"Total time\")\n  \n  call finalize_MPI()\nend program test_SF_TIMER\n",
  "encoding": "utf-8",
